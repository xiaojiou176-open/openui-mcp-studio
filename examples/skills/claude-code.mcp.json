{
  "host": "Claude Code",
  "transport": "stdio",
  "displayName": "openui",
  "config": {
    "command": "node",
    "args": [
      "/ABS/PATH/openui-mcp-studio/.runtime-cache/build/mcp-server/services/mcp-server/src/main.js"
    ],
    "env": {
      "GEMINI_API_KEY": "${GEMINI_API_KEY}"
    }
  },
  "proofCommands": [
    "claude mcp list",
    "node tooling/cli/openui.mjs ecosystem-guide --json",
    "npm run demo:ship"
  ],
  "notFor": [
    "claiming a Claude Code marketplace or plugin listing",
    "claiming a managed hosted runtime"
  ]
}
