{
  "host": "Codex",
  "transport": "stdio",
  "displayName": "openui",
  "config": {
    "command": "node",
    "args": [
      "/ABS/PATH/openui-mcp-studio/.runtime-cache/build/mcp-server/services/mcp-server/src/main.js"
    ],
    "env": {
      "GEMINI_API_KEY": "${GEMINI_API_KEY}"
    }
  },
  "proofCommands": [
    "codex mcp list",
    "node tooling/cli/openui.mjs surface-guide",
    "npm run demo:ship"
  ],
  "notFor": [
    "claiming a Codex marketplace item",
    "claiming vendor approval beyond the documented MCP install path"
  ]
}
