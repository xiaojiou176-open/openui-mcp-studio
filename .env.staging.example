# OpenUI MCP staging profile (non-secret example values)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_MODEL_FAST=gemini-3-flash-preview
GEMINI_MODEL_STRONG=gemini-3.1-pro-preview
GEMINI_MODEL_EMBEDDING=gemini-embedding-001
GEMINI_DEFAULT_THINKING_LEVEL=high
GEMINI_DEFAULT_TEMPERATURE=1.0
OPENUI_MODEL_ROUTING=on
OPENUI_MCP_WORKSPACE_ROOT=.
OPENUI_TIMEOUT_MS=60000
OPENUI_MAX_RETRIES=3
OPENUI_RETRY_BASE_MS=600
OPENUI_MCP_LOG_LEVEL=info
OPENUI_MCP_LOG_OUTPUT=both
OPENUI_MCP_LOG_ROTATE_ON_START=on
OPENUI_MCP_CHILD_ENV_ALLOWLIST=OPENUI_*,PATH,HOME,TMPDIR,TMP,TEMP,CI,NODE_ENV,GEMINI_*
OPENUI_MCP_LOG_DIR=.runtime-cache/runs/<run_id>/logs/runtime.jsonl
OPENUI_MCP_LOG_RETENTION_DAYS=14
OPENUI_MCP_LOG_MAX_FILE_MB=20
OPENUI_MCP_CACHE_DIR=.runtime-cache/cache/staging
OPENUI_MCP_CACHE_RETENTION_DAYS=14
OPENUI_MCP_CACHE_MAX_BYTES=209715200
OPENUI_MCP_CACHE_CLEAN_INTERVAL_MINUTES=30
OPENUI_QUEUE_CONCURRENCY=1
OPENUI_QUEUE_MAX_PENDING=128
OPENUI_IDEMPOTENCY_TTL_MINUTES=1440
OPENUI_GEMINI_PYTHON_BIN=python3
OPENUI_GEMINI_SIDECAR_PATH=services/gemini-sidecar/server.py
OPENUI_GEMINI_SIDECAR_STDOUT_BUFFER_MAX_BYTES=262144
